<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical">
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/cardview6"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginLeft="4dp"
		android:layout_marginTop="4dp"
		android:layout_marginRight="4dp"
		android:layout_marginBottom="8dp"
		app:cardBackgroundColor="#131B2D"
		app:cardCornerRadius="16dp"
		app:strokeColor="#1E293B"
		app:strokeWidth="1dp"
		app:cardElevation="0dp">
		<RelativeLayout
			android:id="@+id/relativelayout4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="12dp">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/btn_play_item"
				android:layout_width="56dp"
				android:layout_height="56dp"
				app:cardBackgroundColor="#1D61FF"
				app:cardCornerRadius="28dp"
				app:strokeWidth="0dp"
				app:cardElevation="2dp"
				android:layout_centerVertical="true">
				<ImageView
					android:id="@+id/img_play_pause"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="14dp"
					android:src="@drawable/icon_play_circle"
					android:scaleType="fitXY"
					android:focusable="false"
					app:tint="#FFFFFF" />
			</com.google.android.material.card.MaterialCardView>
			<ImageView
				android:id="@+id/btn_share"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_ios_share"
				android:scaleType="fitXY"
				android:focusable="false"
				app:tint="#A0AEC0"
				android:layout_alignParentEnd="true"
				android:layout_centerVertical="true" />
			<ImageView
				android:id="@+id/btn_favorite"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_favorite_outline"
				android:scaleType="fitXY"
				android:focusable="false"
				android:layout_marginEnd="16dp"
				app:tint="#A0AEC0"
				android:layout_toStartOf="@id/btn_share"
				android:layout_centerVertical="true" />
			<LinearLayout
				android:id="@+id/linear9"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_marginStart="16dp"
				android:layout_marginEnd="16dp"
				android:layout_toStartOf="@id/btn_favorite"
				android:layout_toEndOf="@id/btn_play_item"
				android:layout_centerVertical="true">
				<TextView
					android:id="@+id/txt_title"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="The quick brown fox ju..."
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF"
					android:focusable="false"
					android:ellipsize="end"
					android:maxLines="1" />
				<TextView
					android:id="@+id/txt_meta"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="00:45  •  Oct 24, 2023"
					android:textSize="12sp"
					android:textColor="#718096"
					android:focusable="false" />
				<LinearLayout
					android:id="@+id/linear10"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/imageview4"
						android:layout_width="14dp"
						android:layout_height="14dp"
						android:src="@drawable/icon_mic"
						android:scaleType="fitXY"
						android:focusable="false"
						app:tint="#1D61FF" />
					<TextView
						android:id="@+id/txt_voice_name"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Nova (ONNX)"
						android:textSize="12sp"
						android:textColor="#1D61FF"
						android:focusable="false"
						android:layout_marginStart="3dp"
						android:ellipsize="end"
						android:maxLines="1" />
				</LinearLayout>
			</LinearLayout>
		</RelativeLayout>
	</com.google.android.material.card.MaterialCardView>
</LinearLayout>

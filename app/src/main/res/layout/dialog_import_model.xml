<androidx.core.widget.NestedScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@drawable/bg_bottom_sheet"
	android:fillViewport="true">
	<LinearLayout
		android:id="@+id/linear2"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:paddingTop="12dp"
		android:paddingBottom="48dp"
		android:orientation="vertical"
		android:paddingStart="20dp"
		android:paddingEnd="20dp">
		<View
			android:id="@+id/view7"
			android:layout_width="40dp"
			android:layout_height="4dp"
			android:layout_marginBottom="24dp"
			android:background="#3E495E"
			android:layout_gravity="center_horizontal" />
		<RelativeLayout
			android:id="@+id/relativelayout2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp">
			<TextView
				android:id="@+id/textview10"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Import Model"
				android:textSize="20sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:focusable="false"
				android:layout_centerVertical="true" />
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/btn_close"
				android:layout_width="32dp"
				android:layout_height="32dp"
				app:cardBackgroundColor="#1E293B"
				app:cardCornerRadius="16dp"
				app:strokeWidth="0dp"
				android:layout_alignParentEnd="true"
				android:layout_centerVertical="true">
				<ImageView
					android:id="@+id/imageview7"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:src="@drawable/ic_close"
					android:scaleType="fitCenter"
					android:focusable="false"
					app:tint="#A0AEC0" />
			</com.google.android.material.card.MaterialCardView>
		</RelativeLayout>
		<TextView
			android:id="@+id/textview11"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			android:text="Select local ONNX weights and tokens file"
			android:textSize="14sp"
			android:textColor="#718096"
			android:focusable="false" />
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/btn_choose_onnx"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			app:cardBackgroundColor="#131B2D"
			app:cardCornerRadius="16dp"
			app:cardElevation="0dp"
			app:strokeColor="#3E495E"
			app:strokeWidth="1.5dp">
			<LinearLayout
				android:id="@+id/linear8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="24dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/cardview5"
					android:layout_width="48dp"
					android:layout_height="48dp"
					app:cardBackgroundColor="#2D3748"
					app:cardCornerRadius="24dp"
					app:strokeWidth="0dp">
					<ImageView
						android:id="@+id/imageview8"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="12dp"
						android:src="@drawable/icon_model_selected"
						android:scaleType="fitCenter"
						android:focusable="false"
						app:tint="#FFFFFF" />
				</com.google.android.material.card.MaterialCardView>
				<TextView
					android:id="@+id/onnx_name_tv"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="12dp"
					android:text="Choose .onnx file"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF"
					android:focusable="false" />
				<TextView
					android:id="@+id/textview13"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="Neural network weights &amp; architecture"
					android:textSize="12sp"
					android:textColor="#718096"
					android:focusable="false" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/btn_select_tokens"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			app:cardBackgroundColor="#131B2D"
			app:cardCornerRadius="16dp"
			app:cardElevation="0dp"
			app:strokeColor="#3E495E"
			app:strokeWidth="1.5dp">
			<LinearLayout
				android:id="@+id/linear10"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="24dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/cardview7"
					android:layout_width="48dp"
					android:layout_height="48dp"
					app:cardBackgroundColor="#2D3748"
					app:cardCornerRadius="24dp"
					app:strokeWidth="0dp">
					<ImageView
						android:id="@+id/imageview10"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="12dp"
						android:src="@drawable/ic_settings_list"
						android:scaleType="fitCenter"
						android:focusable="false"
						app:tint="#FFFFFF" />
				</com.google.android.material.card.MaterialCardView>
				<TextView
					android:id="@+id/tokens_txt_tv"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="12dp"
					android:text="Select tokens.txt"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF"
					android:focusable="false" />
				<TextView
					android:id="@+id/textview16"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="Phonemes mapping &amp; linguistic tokens"
					android:textSize="12sp"
					android:textColor="#718096"
					android:focusable="false" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<TextView
			android:id="@+id/textview2"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:text="MODEL DETAILS"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#566580"
			android:focusable="false"
			android:letterSpacing="0.05" />
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			android:orientation="horizontal"
			android:baselineAligned="false">
			<LinearLayout
				android:id="@+id/linear5"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1"
				android:layout_marginEnd="8dp">
				<com.google.android.material.textfield.TextInputLayout
					android:id="@+id/textinputlayout3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
					app:boxBackgroundColor="#131B2D"
					app:boxStrokeColor="#1E293B"
					app:boxStrokeWidth="1.5dp"
					app:boxCornerRadiusTopStart="12dp"
					app:boxCornerRadiusTopEnd="12dp"
					app:boxCornerRadiusBottomStart="12dp"
					app:boxCornerRadiusBottomEnd="12dp"
					app:hintTextColor="#718096">
					<AutoCompleteTextView
						android:id="@+id/dropdown_lang"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:paddingTop="14dp"
						android:paddingBottom="14dp"
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:focusable="false"
						android:popupBackground="#1E293B" />
				</com.google.android.material.textfield.TextInputLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear6"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1"
				android:layout_marginStart="8dp">
				<com.google.android.material.textfield.TextInputLayout
					android:id="@+id/textinputlayout4"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
					app:boxBackgroundColor="#131B2D"
					app:boxStrokeColor="#1E293B"
					app:boxStrokeWidth="1.5dp"
					app:boxCornerRadiusTopStart="12dp"
					app:boxCornerRadiusTopEnd="12dp"
					app:boxCornerRadiusBottomStart="12dp"
					app:boxCornerRadiusBottomEnd="12dp"
					app:hintTextColor="#718096">
					<AutoCompleteTextView
						android:id="@+id/dropdown_gender"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:paddingTop="14dp"
						android:paddingBottom="14dp"
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:focusable="false"
						android:popupBackground="#1E293B" />
				</com.google.android.material.textfield.TextInputLayout>
			</LinearLayout>
		</LinearLayout>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview8"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="28dp"
			app:cardBackgroundColor="#0F172A"
			app:cardCornerRadius="12dp"
			app:strokeWidth="0dp">
			<LinearLayout
				android:id="@+id/linear11"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="16dp"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/imageview11"
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:src="@drawable/ic_info"
					android:scaleType="fitCenter"
					android:focusable="false"
					app:tint="#1D61FF" />
				<TextView
					android:id="@+id/info_tv"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Please ensure you select a compatible Sherpa-ONNX TTS model. The .onnx file handles acoustic synthesis, while the tokens.txt file maps text to valid phonetic representations."
					android:textSize="12sp"
					android:textColor="#A0AEC0"
					android:layout_weight="1"
					android:focusable="false"
					android:layout_marginStart="12dp"
					android:lineSpacingExtra="3dp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/btn_import_to_library"
			android:layout_width="match_parent"
			android:layout_height="54dp"
			app:cardBackgroundColor="#1D61FF"
			app:cardCornerRadius="27dp"
			app:cardElevation="0dp"
			app:strokeWidth="0dp">
			<LinearLayout
				android:id="@+id/linear12"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/imageview12"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/ic_download"
					android:scaleType="fitCenter"
					android:focusable="false"
					app:tint="#FFFFFF" />
				<TextView
					android:id="@+id/textview18"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Import to Library"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF"
					android:focusable="false"
					android:layout_marginStart="12dp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
	</LinearLayout>
</androidx.core.widget.NestedScrollView>

<RelativeLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="true"
	android:background="#0B1220">
	<androidx.viewpager2.widget.ViewPager2
		android:id="@+id/viewpager"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_above="@id/bottom_nav_container" />
	<LinearLayout
		android:id="@+id/bottom_nav_container"
		android:layout_width="match_parent"
		android:layout_height="80dp"
		android:background="#0B1220"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="horizontal"
		android:weightSum="4"
		android:elevation="8dp"
		android:layout_alignParentBottom="true">
		<LinearLayout
			android:id="@+id/nav_generate"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_weight="1"
			android:focusable="true">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/bg_generate"
				android:layout_width="56dp"
				android:layout_height="32dp"
				app:cardBackgroundColor="#1D61FF"
				app:cardCornerRadius="16dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">
				<LinearLayout
					android:id="@+id/linear59"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="center_horizontal|center_vertical">
					<ImageView
						android:id="@+id/icon_generate"
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/icon_campaign"
						android:scaleType="fitCenter"
						app:tint="#FFFFFF" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<TextView
				android:id="@+id/txt_generate"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Generate"
				android:textSize="11sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/nav_models"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_weight="1"
			android:focusable="true">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/bg_models"
				android:layout_width="56dp"
				android:layout_height="32dp"
				app:cardBackgroundColor="@android:color/transparent"
				app:cardCornerRadius="16dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">
				<LinearLayout
					android:id="@+id/linear60"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="center_horizontal|center_vertical">
					<ImageView
						android:id="@+id/icon_models"
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/icon_memory"
						android:scaleType="fitCenter"
						app:tint="#8E99AF" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<TextView
				android:id="@+id/txt_models"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Models"
				android:textSize="11sp"
				android:textColor="#8E99AF" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/nav_library"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_weight="1"
			android:focusable="true">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/bg_library"
				android:layout_width="56dp"
				android:layout_height="32dp"
				app:cardBackgroundColor="@android:color/transparent"
				app:cardCornerRadius="16dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">
				<LinearLayout
					android:id="@+id/linear61"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="center_horizontal|center_vertical">
					<ImageView
						android:id="@+id/icon_library"
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/icon_library_music"
						android:scaleType="fitCenter"
						app:tint="#8E99AF" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<TextView
				android:id="@+id/txt_library"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Library"
				android:textSize="11sp"
				android:textColor="#8E99AF" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/nav_settings"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_weight="1"
			android:focusable="true">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/bg_settings"
				android:layout_width="56dp"
				android:layout_height="32dp"
				app:cardBackgroundColor="@android:color/transparent"
				app:cardCornerRadius="16dp"
				app:cardElevation="0dp"
				app:strokeWidth="0dp">
				<LinearLayout
					android:id="@+id/linear62"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="center_horizontal|center_vertical">
					<ImageView
						android:id="@+id/icon_settings"
						android:layout_width="22dp"
						android:layout_height="22dp"
						android:src="@drawable/icon_settings"
						android:scaleType="fitCenter"
						app:tint="#8E99AF" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<TextView
				android:id="@+id/txt_settings"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Settings"
				android:textSize="11sp"
				android:textColor="#8E99AF" />
		</LinearLayout>
	</LinearLayout>
</RelativeLayout>
